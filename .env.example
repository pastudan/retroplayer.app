# Spotify app client ID (public — safe to expose)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id

# The origin where this app is hosted (used as PKCE redirect base)
VITE_ORIGIN=http://localhost:5173

# URL of the discography Cloudflare Worker (optional — singles won't stream without it)
VITE_DISCOGRAPHY_URL=https://retroplayer-discography.your-subdomain.workers.dev
